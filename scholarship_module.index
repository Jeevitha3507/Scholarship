  {emisId:'33050101901011',name:'Kavitha L.',class:'3',section:'A',gender:'Female',community:'SC',parentIncome:'18000',bankName:'State Bank of India',accountNo:'31201234560',ifsc:'SBIN0002345',scholarships:['SC/ST Pre Matric','Kalvi Thittam Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-12 16:00:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901012',name:'Lingesh T.',class:'5',section:'B',gender:'Male',community:'BC',parentIncome:'62000',bankName:'Canara Bank',accountNo:'0124000123456',ifsc:'CNRB0001234',scholarships:['BC Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-13 11:22:45',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901013',name:'Meenakshi A.',class:'8',section:'A',gender:'Female',community:'ST',parentIncome:'29000',bankName:'Bank of India',accountNo:'894020110000123',ifsc:'BKID0008940',scholarships:['SC/ST Post Matric','Tribal Welfare Scholarship'],cwsn:'Not Applicable',seedingStatus:'Not Seeded',npciTimestamp:'',paymentStatus:'Failed',failureReason:'IFSC code incorrect'},
  {emisId:'33050101901014',name:'Naveen R.',class:'12',section:'B',gender:'Male',community:'OBC',parentIncome:'91000',bankName:'Union Bank of India',accountNo:'0599101234567',ifsc:'UBIN0805991',scholarships:['OBC Scholarship','Merit Cum Means Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-18 10:00:30',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901015',name:'Oviya S.',class:'4',section:'C',gender:'Female',community:'MBC',parentIncome:'37000',bankName:'Central Bank of India',accountNo:'1234567890123',ifsc:'CBIN0283023',scholarships:['MBC Scholarship','Paali Kalvi Thittam'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'',paymentStatus:'Pending',failureReason:''},
  {emisId:'33050101901016',name:'Prakash N.',class:'7',section:'A',gender:'Male',community:'SC',parentIncome:'44000',bankName:'Indian Bank',accountNo:'6234567890',ifsc:'IDIB000B017',scholarships:['SC/ST Pre Matric'],cwsn:'Mentally Challenged',seedingStatus:'Seeded',npciTimestamp:'2024-03-11 09:45:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901017',name:'Rajalakshmi C.',class:'11',section:'A',gender:'Female',community:'BC',parentIncome:'53000',bankName:'Karur Vysya Bank',accountNo:'1611135000000123',ifsc:'KVBL0001611',scholarships:['BC Scholarship','NSP Central Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'',paymentStatus:'Processing',failureReason:''},
  {emisId:'33050101901018',name:'Senthil M.',class:'9',section:'B',gender:'Male',community:'General',parentIncome:'102000',bankName:'ICICI Bank',accountNo:'050901501234567',ifsc:'ICIC0000509',scholarships:['Merit Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-19 13:12:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901019',name:'Tamilselvi G.',class:'6',section:'D',gender:'Female',community:'SC',parentIncome:'21000',bankName:'',accountNo:'',ifsc:'',scholarships:['SC/ST Pre Matric'],cwsn:'Not Applicable',seedingStatus:'Not Seeded',npciTimestamp:'',paymentStatus:'Failed',failureReason:'Bank account not registered'},
  {emisId:'33050101901020',name:'Udhayakumar P.',class:'10',section:'C',gender:'Male',community:'MBC',parentIncome:'67000',bankName:'South Indian Bank',accountNo:'0757053000000123',ifsc:'SIBL0000757',scholarships:['MBC Scholarship','CM Special Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-20 08:30:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901021',name:'Vasantha K.',class:'2',section:'A',gender:'Female',community:'OBC',parentIncome:'38000',bankName:'Indian Overseas Bank',accountNo:'019302000005678',ifsc:'IOBA0002345',scholarships:['OBC Pre Matric'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-10 15:00:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901022',name:'Wajid A.',class:'8',section:'C',gender:'Male',community:'General',parentIncome:'79000',bankName:'Axis Bank',accountNo:'919020060987654',ifsc:'UTIB0000064',scholarships:['Minority Scholarship','NSP Central Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'',paymentStatus:'Pending',failureReason:''},
  {emisId:'33050101901023',name:'Xavier F.',class:'12',section:'C',gender:'Male',community:'BC',parentIncome:'58000',bankName:'State Bank of India',accountNo:'31205556677',ifsc:'SBIN0003456',scholarships:['BC Scholarship'],cwsn:'Not Applicable',seedingStatus:'Not Seeded',npciTimestamp:'',paymentStatus:'Failed',failureReason:''},
  {emisId:'33050101901024',name:'Yamuna D.',class:'1',section:'A',gender:'Female',community:'SC',parentIncome:'15000',bankName:'UCO Bank',accountNo:'03880100009999',ifsc:'UCBA0000389',scholarships:['SC/ST Pre Matric'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-09 12:00:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901025',name:'Zubair M.',class:'11',section:'B',gender:'Male',community:'General',parentIncome:'87000',bankName:'HDFC Bank',accountNo:'50100345678912',ifsc:'HDFC0002345',scholarships:['Minority Scholarship','Merit Cum Means Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-21 10:15:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901026',name:'Abinaya T.',class:'7',section:'C',gender:'Female',community:'MBC',parentIncome:'43000',bankName:'City Union Bank',accountNo:'510909010001234',ifsc:'CIUB0000046',scholarships:['MBC Scholarship'],cwsn:'Visually Impaired',seedingStatus:'Seeded',npciTimestamp:'',paymentStatus:'Pending',failureReason:''},
  {emisId:'33050101901027',name:'Balamurugan V.',class:'4',section:'B',gender:'Male',community:'ST',parentIncome:'22000',bankName:'Bank of Baroda',accountNo:'19340100054321',ifsc:'BARB0DBTCHE',scholarships:['SC/ST Pre Matric','Tribal Welfare Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-08 11:00:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901028',name:'Chandralekha N.',class:'9',section:'D',gender:'Female',community:'SC',parentIncome:'33000',bankName:'Punjab National Bank',accountNo:'0099000345670',ifsc:'PUNB0020000',scholarships:['SC/ST Post Matric','Girls Education Scheme'],cwsn:'Not Applicable',seedingStatus:'Not Seeded',npciTimestamp:'',paymentStatus:'Failed',failureReason:'Name mismatch in records'},
  {emisId:'33050101901029',name:'Deepak S.',class:'3',section:'B',gender:'Male',community:'OBC',parentIncome:'51000',bankName:'Indian Bank',accountNo:'6345678901',ifsc:'IDIB000D023',scholarships:['OBC Pre Matric'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-22 09:00:00',paymentStatus:'Success',failureReason:''},
  {emisId:'33050101901030',name:'Ezhilarasi M.',class:'5',section:'A',gender:'Female',community:'BC',parentIncome:'46000',bankName:'Canara Bank',accountNo:'0125000234567',ifsc:'CNRB0001345',scholarships:['BC Scholarship','Kalvi Thittam Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-23 14:20:00',paymentStatus:'Success',failureReason:''}
];

// ── STATE ──
let filteredData = [...SAMPLE_DATA];
let currentPage = 1;
let sortCol = '';
let sortDir = 1;
let perPage = 20;

// ── INIT ──
function init(){
  updateStats(SAMPLE_DATA);
  applyFilters();
}

// ── STATS ──
function updateStats(data){
  document.getElementById('stat-total').textContent = data.length;
  document.getElementById('stat-success').textContent = data.filter(d=>d.paymentStatus==='Success').length;
  document.getElementById('stat-pending').textContent = data.filter(d=>['Pending','Processing'].includes(d.paymentStatus)).length;
  document.getElementById('stat-failed').textContent = data.filter(d=>d.paymentStatus==='Failed').length;
  document.getElementById('stat-seeded').textContent = data.filter(d=>d.seedingStatus==='Seeded').length;
}

// ── FILTERS ──
function applyFilters(){
  const cls = document.getElementById('class-filter').value;
  const sec = document.getElementById('section-filter').value;
  const stat = document.getElementById('status-filter').value;
  const comm = document.getElementById('comm-filter').value;
  const q = document.getElementById('search-input').value.toLowerCase().trim();
  perPage = parseInt(document.getElementById('per-page').value);
  currentPage = 1;

  filteredData = SAMPLE_DATA.filter(d=>{
    if(cls && d.class !== cls) return false;
    if(sec && d.section !== sec) return false;
    if(stat && d.paymentStatus !== stat) return false;
    if(comm && d.community !== comm) return false;
    if(q){
      const haystack = [d.emisId,d.name,d.class,d.scholarships.join(' '),d.community,d.bankName].join(' ').toLowerCase();
      if(!haystack.includes(q)) return false;
    }
    return true;
  });

  if(sortCol) sortData();
  updateStats(filteredData);
  renderTable();
}

function resetFilters(){
  document.getElementById('class-filter').value='';
  document.getElementById('section-filter').value='';
  document.getElementById('status-filter').value='';
  document.getElementById('comm-filter').value='';
  document.getElementById('search-input').value='';
  applyFilters();
}

// ── SORT ──
function sortTable(col){
  if(sortCol===col) sortDir*=-1;
  else { sortCol=col; sortDir=1; }
  document.querySelectorAll('thead th').forEach(th=>{
    th.classList.remove('sort-asc','sort-desc','sorted');
  });
  const thMap={emisId:0,name:1,class:2,section:3,gender:4,community:5,parentIncome:6,bankName:7,seedingStatus:12,npciTimestamp:13,paymentStatus:14};
  const idx=thMap[col];
  if(idx!==undefined){
    const th=document.querySelectorAll('thead th')[idx];
    th.classList.add(sortDir===1?'sort-asc':'sort-desc','sorted');
  }
  sortData();
  renderTable();
}
function sortData(){
  filteredData.sort((a,b)=>{
    let va=a[sortCol]||'';
    let vb=b[sortCol]||'';
    if(sortCol==='parentIncome'){va=parseInt(va)||0;vb=parseInt(vb)||0;}
    if(sortCol==='class'){va=parseInt(va)||0;vb=parseInt(vb)||0;}
    if(va<vb)return -1*sortDir;
    if(va>vb)return 1*sortDir;
    return 0;
  });
}

// ── RENDER ──
function na(val,fallback='Not Available'){
  if(!val||val.trim()==='') return `<span class="td-na">${fallback}</span>`;
  return val;
}
function payBadge(s){
  const m={Success:'s-success Success',Failed:'s-failed Failed',Pending:'s-pending Pending',Processing:'s-processing Processing'};
  const cls=m[s]||'s-pending';
  return `<span class="status-badge ${cls.split(' ')[0]}">${cls.split(' ')[1]||s}</span>`;
}
function seedBadge(s){
  if(!s||s.trim()==='') return `<span class="status-badge s-pending">Unknown</span>`;
  if(s==='Seeded') return `<span class="status-badge s-seeded">Seeded</span>`;
  return `<span class="status-badge s-not-seeded">Not Seeded</span>`;
}
function commTag(c){
  const m={SC:'comm-sc',ST:'comm-st',OBC:'comm-obc',MBC:'comm-mbc',BC:'comm-bc',General:'comm-gen'};
  const cls=m[c]||'comm-gen';
  return `<span class="comm-tag ${cls}">${c}</span>`;
}
function scholarshipPills(arr){
  if(!arr||arr.length===0) return `<span class="td-na">Not Available</span>`;
  return arr.map(s=>`<span class="sch-pill">${s}</span>`).join('');
}
function genderCell(g){
  const cls=g==='Male'?'g-male':g==='Female'?'g-female':'g-other';
  return `<span class="${cls}">${g||'—'}</span>`;
}
function cwsnCell(v){
  if(!v||v==='Not Applicable') return `<span class="cwsn-no">—</span>`;
  return `<span class="cwsn-yes">${v}</span>`;
}
function failCell(s,r){
  if(s!=='Failed') return `<span class="td-na">—</span>`;
  if(!r||r.trim()==='') return `<span class="reason-na">Reason not provided</span>`;
  return `<span class="fail-reason" title="${r}">${r}</span>`;
}

function renderTable(){
  const tbody = document.getElementById('table-body');
  const noData = document.getElementById('no-data');
  const totalPages = Math.max(1, Math.ceil(filteredData.length/perPage));
  if(currentPage>totalPages) currentPage=totalPages;
  const start=(currentPage-1)*perPage;
  const end=Math.min(start+perPage,filteredData.length);
  const pageData=filteredData.slice(start,end);

  document.getElementById('result-count').innerHTML=
    `Showing <strong>${filteredData.length===0?0:start+1}–${end}</strong> of <strong>${filteredData.length}</strong> records`;

  if(filteredData.length===0){
    tbody.innerHTML='';
    noData.style.display='block';
    document.getElementById('page-info').innerHTML='Page <strong>0</strong> of <strong>0</strong>';
    document.getElementById('page-btns').innerHTML='';
    return;
  }
  noData.style.display='none';

  tbody.innerHTML = pageData.map(d=>`
    <tr>
      <td class="col-freeze"><span class="td-emis">${d.emisId}</span></td>
      <td class="td-name">${d.name}</td>
      <td style="font-weight:600;color:var(--ink)">Class ${d.class}</td>
      <td style="font-weight:500">${d.section||'—'}</td>
      <td>${genderCell(d.gender)}</td>
      <td>${commTag(d.community)}</td>
      <td class="td-income">₹ ${d.parentIncome?parseInt(d.parentIncome).toLocaleString('en-IN'):na('')}</td>
      <td>${d.bankName||`<span class="td-na">Not Available</span>`}</td>
      <td><span class="td-account">${d.accountNo||`<span class="td-na">Not Available</span>`}</span></td>
      <td><span class="td-ifsc">${d.ifsc||`<span class="td-na">Not Available</span>`}</span></td>
      <td class="td-scholarships">${scholarshipPills(d.scholarships)}</td>
      <td>${cwsnCell(d.cwsn)}</td>
      <td>${seedBadge(d.seedingStatus)}</td>
      <td style="font-size:11.5px;color:var(--gray2);font-variant-numeric:tabular-nums">${d.npciTimestamp||`<span class="td-na">Pending</span>`}</td>
      <td>${payBadge(d.paymentStatus)}</td>
      <td>${failCell(d.paymentStatus,d.failureReason)}</td>
    </tr>
  `).join('');

  // Pagination
  document.getElementById('page-info').innerHTML=
    `Page <strong>${currentPage}</strong> of <strong>${totalPages}</strong>`;
  renderPagination(totalPages);
}

function renderPagination(total){
  const container=document.getElementById('page-btns');
  const btns=[];
  btns.push(`<button class="page-btn page-btn-text" onclick="changePage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹ Prev</button>`);
  const range=[];
  for(let i=1;i<=total;i++){
    if(i===1||i===total||Math.abs(i-currentPage)<=2) range.push(i);
    else if(range[range.length-1]!=='…') range.push('…');
  }
  range.forEach(r=>{
    if(r==='…') btns.push(`<span style="padding:0 4px;color:var(--gray3)">…</span>`);
    else btns.push(`<button class="page-btn${r===currentPage?' active':''}" onclick="changePage(${r})">${r}</button>`);
  });
  btns.push(`<button class="page-btn page-btn-text" onclick="changePage(${currentPage+1})" ${currentPage===total?'disabled':''}>Next ›</button>`);
  container.innerHTML=btns.join('');
}

function changePage(p){
  const total=Math.ceil(filteredData.length/perPage);
  if(p<1||p>total)return;
  currentPage=p;
  renderTable();
  document.querySelector('.table-wrapper').scrollIntoView({behavior:'smooth',block:'start'});
}

// ── EXPORT CSV ──
function exportCSV(){
  const headers=['EMIS ID','Name','Class','Section','Gender','Community','Parent Income','Bank Name','Account Number','IFSC Code','Scholarship Name(s)','CWSN Disability','Bank Seeding Status','NPCI Timestamp','Payment Status','Failure Reason'];
  const rows=filteredData.map(d=>[
    d.emisId,d.name,'Class '+d.class,d.section,d.gender,d.community,
    d.parentIncome?'₹'+d.parentIncome:'Not Available',
    d.bankName||'Not Available',d.accountNo||'Not Available',d.ifsc||'Not Available',
    d.scholarships.join('; ')||'Not Available',
    d.cwsn||'Not Applicable',d.seedingStatus||'Unknown',
    d.npciTimestamp||'Pending',d.paymentStatus,
    d.paymentStatus==='Failed'?(d.failureReason||'Reason not provided'):'—'
  ]);
  const csv=[headers,...rows].map(r=>r.map(c=>`"${c}"`).join(',')).join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download='scholarship_module_'+new Date().toISOString().slice(0,10)+'.csv';
  a.click();
  toggleExport();
}

// ── EXPORT DROPDOWN ──
function toggleExport(e){
  const m=document.getElementById('export-menu');
  m.classList.toggle('open');
  if(e) e.stopPropagation();
}
document.addEventListener('click',()=>document.getElementById('export-menu').classList.remove('open'));

// ── START ──
init();
</script>
</body>
</html>
