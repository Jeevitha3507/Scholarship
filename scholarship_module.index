<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Unified Scholarship Module — EMIS School Portal</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0f2d5c;--navy2:#163572;--navy3:#1e4080;
  --blue:#1a6bdb;--blue-lt:#dbeafe;--blue-dk:#1241a8;
  --teal:#0891b2;--teal-lt:#e0f7fa;
  --green:#059669;--green-lt:#d1fae5;--green-dk:#047857;
  --amber:#b45309;--amber-lt:#fef3c7;
  --red:#b91c1c;--red-lt:#fee2e2;
  --gray:#374151;--gray2:#6b7280;--gray3:#9ca3af;
  --line:#e5e7eb;--line2:#d1d5db;
  --paper:#f8fafc;--paper2:#f1f5f9;
  --white:#ffffff;
  --ink:#111827;--ink2:#1f2937;
  --r:6px;--r-lg:10px;--r-xl:14px;
  font-family:'DM Sans',sans-serif;font-size:13px;
}
html,body{min-height:100%;background:var(--paper);color:var(--ink)}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--line2);border-radius:3px}

/* ── TOPBAR ── */
.topbar{background:var(--navy);padding:0 24px;height:56px;display:flex;align-items:center;gap:14px;position:sticky;top:0;z-index:100;border-bottom:1px solid rgba(255,255,255,.08)}
.emblem{width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.portal-name{color:#fff;font-size:14px;font-weight:700;letter-spacing:-.2px;line-height:1.2}
.portal-sub{color:rgba(255,255,255,.5);font-size:10px;font-weight:400}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:12px}
.school-chip{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:5px 12px;font-size:11px;color:rgba(255,255,255,.85);font-weight:500}
.user-av{width:32px;height:32px;border-radius:50%;background:var(--blue);border:2px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;cursor:pointer}

/* ── BREADCRUMB ── */
.breadcrumb{background:var(--white);border-bottom:1px solid var(--line);padding:10px 24px;display:flex;align-items:center;gap:6px;font-size:12px;color:var(--gray2)}
.breadcrumb a{color:var(--blue);text-decoration:none;cursor:pointer}
.breadcrumb a:hover{text-decoration:underline}
.bc-sep{color:var(--gray3)}
.bc-current{color:var(--ink);font-weight:600}

/* ── MAIN CONTAINER ── */
.main{padding:20px 24px;max-width:1600px}

/* ── PAGE TITLE ── */
.page-title-block{margin-bottom:18px}
.page-title{font-size:20px;font-weight:700;color:var(--ink);display:flex;align-items:center;gap:10px}
.page-title-icon{width:36px;height:36px;background:var(--navy);border-radius:var(--r-lg);display:flex;align-items:center;justify-content:center}
.page-title-icon svg{width:18px;height:18px;stroke:#fff;fill:none}
.page-sub{font-size:12px;color:var(--gray2);margin-top:4px;margin-left:46px}

/* ── STAT CARDS ── */
.stat-row{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:12px;margin-bottom:18px}
.stat-card{background:var(--white);border:1px solid var(--line);border-radius:var(--r-lg);padding:14px 16px;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.stat-card.blue::before{background:var(--blue)}
.stat-card.green::before{background:var(--green)}
.stat-card.amber::before{background:#d97706}
.stat-card.red::before{background:var(--red)}
.stat-card.teal::before{background:var(--teal)}
.stat-label{font-size:10.5px;font-weight:600;color:var(--gray2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.stat-val{font-size:24px;font-weight:700;color:var(--ink);font-variant-numeric:tabular-nums;line-height:1}
.stat-note{font-size:10.5px;color:var(--gray3);margin-top:4px}

/* ── FILTER BAR ── */
.filter-bar{background:var(--white);border:1px solid var(--line);border-radius:var(--r-lg);padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.filter-label{font-size:11px;font-weight:700;color:var(--gray2);text-transform:uppercase;letter-spacing:.5px;white-space:nowrap}
.filter-group{display:flex;align-items:center;gap:8px}
.fi{background:var(--paper);border:1px solid var(--line2);border-radius:var(--r);padding:7px 10px;font-size:12.5px;color:var(--ink);font-family:inherit;outline:none;transition:border .15s;min-width:140px}
.fi:focus{border-color:var(--blue);background:var(--white);box-shadow:0 0 0 3px rgba(26,107,219,.1)}
.search-wrap{flex:1;min-width:220px;max-width:360px;position:relative}
.search-wrap svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);width:14px;height:14px;stroke:var(--gray3);pointer-events:none;fill:none}
.search-input{width:100%;background:var(--paper);border:1px solid var(--line2);border-radius:var(--r);padding:7px 10px 7px 30px;font-size:12.5px;color:var(--ink);font-family:inherit;outline:none;transition:all .15s}
.search-input:focus{border-color:var(--blue);background:var(--white);box-shadow:0 0 0 3px rgba(26,107,219,.1)}
.filter-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.btn{padding:7px 14px;border-radius:var(--r);font-size:12px;font-weight:600;cursor:pointer;border:1px solid var(--line2);background:var(--white);color:var(--ink2);transition:all .15s;font-family:inherit;display:inline-flex;align-items:center;gap:5px;white-space:nowrap}
.btn:hover{background:var(--paper2);border-color:var(--gray3)}
.btn svg{width:13px;height:13px;stroke:currentColor;fill:none}
.btn-primary{background:var(--navy);color:#fff;border-color:var(--navy)}
.btn-primary:hover{background:var(--navy2)}
.btn-outline{background:transparent;border-color:var(--blue);color:var(--blue)}
.btn-outline:hover{background:var(--blue-lt)}

/* ── RESULT INFO BAR ── */
.result-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;padding:0 2px}
.result-count{font-size:12px;color:var(--gray2)}
.result-count strong{color:var(--ink);font-weight:700}
.per-page-wrap{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--gray2)}

/* ── TABLE WRAPPER ── */
.table-wrapper{background:var(--white);border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden}
.table-scroll{overflow-x:auto}
.table-scroll::-webkit-scrollbar{height:6px}
.table-scroll::-webkit-scrollbar-track{background:var(--paper2)}
.table-scroll::-webkit-scrollbar-thumb{background:var(--line2);border-radius:3px}

/* ── TABLE ── */
table{width:100%;border-collapse:collapse;white-space:nowrap}
thead{position:sticky;top:0;z-index:10}
thead th{padding:10px 12px;text-align:left;font-size:10.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--gray2);background:var(--paper2);border-bottom:1px solid var(--line);cursor:pointer;user-select:none;transition:background .15s;white-space:nowrap}
thead th:hover{background:var(--paper);color:var(--ink)}
thead th.sort-asc::after{content:' ↑';color:var(--blue)}
thead th.sort-desc::after{content:' ↓';color:var(--blue)}
thead th.sorted{color:var(--blue-dk)}
tbody tr{transition:background .1s}
tbody tr:hover{background:#f0f7ff}
tbody tr:nth-child(even){background:var(--paper)}
tbody tr:nth-child(even):hover{background:#f0f7ff}
tbody td{padding:10px 12px;border-bottom:1px solid var(--line);font-size:12.5px;color:var(--ink2);vertical-align:middle}
tbody tr:last-child td{border-bottom:none}
.td-emis{font-family:'DM Mono',monospace;font-size:11.5px;font-weight:500;color:var(--blue-dk)}
.td-name{font-weight:600;color:var(--ink);min-width:140px}
.td-account{font-family:'DM Mono',monospace;font-size:11.5px;color:var(--gray)}
.td-ifsc{font-family:'DM Mono',monospace;font-size:11.5px;color:var(--gray);letter-spacing:.3px}
.td-scholarships{max-width:220px;white-space:normal;line-height:1.6}
.sch-pill{display:inline-block;background:var(--blue-lt);color:var(--blue-dk);border-radius:20px;padding:1px 7px;font-size:10.5px;font-weight:600;margin:1px 2px 1px 0;white-space:nowrap}
.td-na{color:var(--gray3);font-style:italic;font-size:11.5px}
.td-income{font-variant-numeric:tabular-nums}

/* ── STATUS BADGES ── */
.status-badge{padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;display:inline-flex;align-items:center;gap:4px;white-space:nowrap}
.status-badge::before{content:'';width:6px;height:6px;border-radius:50%;flex-shrink:0}
.s-success{background:var(--green-lt);color:var(--green-dk)}.s-success::before{background:var(--green)}
.s-failed{background:var(--red-lt);color:var(--red)}.s-failed::before{background:var(--red)}
.s-pending{background:var(--amber-lt);color:var(--amber)}.s-pending::before{background:#d97706}
.s-seeded{background:var(--green-lt);color:var(--green-dk)}.s-seeded::before{background:var(--green)}
.s-not-seeded{background:var(--red-lt);color:var(--red)}.s-not-seeded::before{background:var(--red)}
.s-processing{background:#ede9fe;color:#6d28d9}.s-processing::before{background:#7c3aed}

/* GENDER */
.g-male{color:#1d4ed8;font-weight:600}
.g-female{color:#be185d;font-weight:600}
.g-other{color:#7c3aed;font-weight:600}

/* CWSN */
.cwsn-yes{background:#fef3c7;color:#92400e;padding:2px 7px;border-radius:4px;font-size:11px;font-weight:600}
.cwsn-no{color:var(--gray3);font-size:11.5px}

/* ── NO DATA ── */
.no-data{padding:60px 24px;text-align:center}
.no-data-icon{font-size:40px;margin-bottom:12px;opacity:.4}
.no-data-title{font-size:15px;font-weight:700;color:var(--ink2);margin-bottom:4px}
.no-data-sub{font-size:12px;color:var(--gray3)}

/* ── PAGINATION ── */
.pagination-bar{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-top:1px solid var(--line);background:var(--paper2);flex-wrap:wrap;gap:8px}
.page-info{font-size:12px;color:var(--gray2)}
.page-info strong{color:var(--ink);font-weight:700}
.page-btns{display:flex;align-items:center;gap:4px}
.page-btn{width:30px;height:30px;border-radius:var(--r);border:1px solid var(--line2);background:var(--white);color:var(--ink2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;transition:all .15s;font-family:inherit}
.page-btn:hover{background:var(--paper);border-color:var(--gray3)}
.page-btn.active{background:var(--navy);color:#fff;border-color:var(--navy)}
.page-btn:disabled{opacity:.35;cursor:not-allowed}
.page-btn-text{padding:0 12px;width:auto}

/* ── LOADING SKELETON ── */
.skeleton{background:linear-gradient(90deg,var(--paper2) 25%,var(--line) 50%,var(--paper2) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:4px;height:12px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* ── FAILURE REASON TOOLTIP ── */
.fail-reason{font-size:11px;color:var(--red);cursor:help;border-bottom:1px dashed var(--red);display:inline-block;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.reason-na{font-size:11px;color:var(--gray3);font-style:italic}

/* ── RESPONSIVE ── */
@media(max-width:1024px){
  .stat-row{grid-template-columns:repeat(3,1fr)}
  .stat-card:nth-child(4),.stat-card:nth-child(5){display:none}
  .filter-right{width:100%}
}
@media(max-width:768px){
  .main{padding:14px 14px}
  .topbar{padding:0 14px}
  .breadcrumb{padding:8px 14px}
  .stat-row{grid-template-columns:repeat(2,1fr)}
  .stat-card:nth-child(3),.stat-card:nth-child(4),.stat-card:nth-child(5){display:none}
  .filter-bar{flex-direction:column;align-items:stretch}
  .filter-group{flex-wrap:wrap}
  .fi{min-width:unset;width:100%}
  .search-wrap{max-width:unset}
  .filter-right{justify-content:flex-end}
}

/* ── EXPORT DROPDOWN ── */
.export-dropdown{position:relative}
.export-menu{position:absolute;top:calc(100% + 4px);right:0;background:var(--white);border:1px solid var(--line);border-radius:var(--r-lg);min-width:150px;box-shadow:0 4px 12px rgba(0,0,0,.1);z-index:50;display:none}
.export-menu.open{display:block}
.export-item{padding:9px 14px;font-size:12.5px;color:var(--ink2);cursor:pointer;display:flex;align-items:center;gap:8px;transition:background .1s}
.export-item:hover{background:var(--paper2)}
.export-item svg{width:14px;height:14px;stroke:currentColor;fill:none;flex-shrink:0}

/* ── COMMUNITY TAG ── */
.comm-tag{display:inline-block;padding:1px 7px;border-radius:4px;font-size:11px;font-weight:600}
.comm-sc{background:#fef3c7;color:#78350f}
.comm-st{background:#fde8d8;color:#9a3412}
.comm-obc{background:#ede9fe;color:#5b21b6}
.comm-mbc{background:#e0f2fe;color:#075985}
.comm-gen{background:var(--paper2);color:var(--gray2)}
.comm-bc{background:#d1fae5;color:#065f46}

/* COLUMN FREEZE VISUAL */
.col-freeze{position:sticky;left:0;background:inherit;z-index:5;box-shadow:2px 0 4px rgba(0,0,0,.06)}
thead .col-freeze{background:var(--paper2);z-index:6}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="emblem">🏛️</div>
  <div>
    <div class="portal-name">School EMIS Portal</div>
    <div class="portal-sub">Tamil Nadu Government · Education Management Information System</div>
  </div>
  <div class="topbar-right">
    <span class="school-chip">GHS Coimbatore — DISE: 33050101901</span>
    <div class="user-av" title="Headmaster">HM</div>
  </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <a>Home</a><span class="bc-sep">›</span>
  <a>Student Management</a><span class="bc-sep">›</span>
  <a>Student Details</a><span class="bc-sep">›</span>
  <span class="bc-current">Scholarship</span>
</div>

<!-- MAIN -->
<div class="main">

  <!-- PAGE TITLE -->
  <div class="page-title-block">
    <div class="page-title">
      <div class="page-title-icon">
        <svg viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
      </div>
      Unified Scholarship Module
    </div>
    <div class="page-sub">Auto-fetched from TNREGA API · Scholarship-eligible students only · Academic Year 2024–25</div>
  </div>

  <!-- STAT CARDS -->
  <div class="stat-row" id="stat-row">
    <div class="stat-card blue">
      <div class="stat-label">Total Eligible</div>
      <div class="stat-val" id="stat-total">—</div>
      <div class="stat-note">All classes combined</div>
    </div>
    <div class="stat-card green">
      <div class="stat-label">Payment Success</div>
      <div class="stat-val" id="stat-success">—</div>
      <div class="stat-note">NPCI credited</div>
    </div>
    <div class="stat-card amber">
      <div class="stat-label">Pending</div>
      <div class="stat-val" id="stat-pending">—</div>
      <div class="stat-note">Awaiting disbursement</div>
    </div>
    <div class="stat-card red">
      <div class="stat-label">Failed</div>
      <div class="stat-val" id="stat-failed">—</div>
      <div class="stat-note">Action required</div>
    </div>
    <div class="stat-card teal">
      <div class="stat-label">Bank Seeded</div>
      <div class="stat-val" id="stat-seeded">—</div>
      <div class="stat-note">NPCI linked accounts</div>
    </div>
  </div>

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <div class="filter-group">
      <span class="filter-label">Class</span>
      <select class="fi" id="class-filter" onchange="applyFilters()">
        <option value="">All Classes</option>
        <option value="1">Class 1</option>
        <option value="2">Class 2</option>
        <option value="3">Class 3</option>
        <option value="4">Class 4</option>
        <option value="5">Class 5</option>
        <option value="6">Class 6</option>
        <option value="7">Class 7</option>
        <option value="8">Class 8</option>
        <option value="9">Class 9</option>
        <option value="10">Class 10</option>
        <option value="11">Class 11</option>
        <option value="12">Class 12</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">Section</span>
      <select class="fi" id="section-filter" onchange="applyFilters()">
        <option value="">All Sections</option>
        <option value="A">A</option>
        <option value="B">B</option>
        <option value="C">C</option>
        <option value="D">D</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">Status</span>
      <select class="fi" id="status-filter" onchange="applyFilters()">
        <option value="">All Status</option>
        <option value="Success">Success</option>
        <option value="Pending">Pending</option>
        <option value="Failed">Failed</option>
        <option value="Processing">Processing</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">Community</span>
      <select class="fi" id="comm-filter" onchange="applyFilters()">
        <option value="">All Communities</option>
        <option value="SC">SC</option>
        <option value="ST">ST</option>
        <option value="OBC">OBC</option>
        <option value="MBC">MBC</option>
        <option value="BC">BC</option>
        <option value="General">General</option>
      </select>
    </div>
    <div class="search-wrap">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input class="search-input" id="search-input" placeholder="Search by name, EMIS ID, scholarship…" oninput="applyFilters()">
    </div>
    <div class="filter-right">
      <div style="display:flex;align-items:center;gap:5px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:20px;padding:5px 12px;font-size:11px;font-weight:600;color:#166534;">
        <span style="width:7px;height:7px;border-radius:50%;background:#16a34a;display:inline-block;flex-shrink:0"></span>
        API Synced · TNREGA
      </div>
      <button class="btn" onclick="resetFilters()">
        <svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 101.5-5.06"/><path d="M3 3v4h4"/></svg>
        Reset
      </button>
      <div class="export-dropdown">
        <button class="btn btn-outline" onclick="toggleExport(event)">
          <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Export
          <svg viewBox="0 0 24 24" style="width:10px;height:10px"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="export-menu" id="export-menu">
          <div class="export-item" onclick="exportCSV()">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Export as CSV
          </div>
          <div class="export-item" onclick="window.print()">
            <svg viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Print View
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- RESULT INFO BAR -->
  <div class="result-bar">
    <div class="result-count" id="result-count">Showing <strong>—</strong> of <strong>—</strong> records</div>
    <div class="per-page-wrap">
      Rows per page:
      <select class="fi" id="per-page" onchange="applyFilters()" style="min-width:65px;padding:4px 8px;font-size:12px">
        <option value="10">10</option>
        <option value="20" selected>20</option>
        <option value="50">50</option>
        <option value="100">100</option>
      </select>
    </div>
  </div>

  <!-- TABLE -->
  <div class="table-wrapper">
    <div class="table-scroll">
      <table id="scholarship-table">
        <thead>
          <tr>
            <th class="col-freeze" style="min-width:110px" onclick="sortTable('emisId')">EMIS ID</th>
            <th style="min-width:150px" onclick="sortTable('name')">Student Name</th>
            <th style="min-width:70px" onclick="sortTable('class')">Class</th>
            <th style="min-width:70px" onclick="sortTable('section')">Section</th>
            <th style="min-width:70px" onclick="sortTable('gender')">Gender</th>
            <th style="min-width:90px" onclick="sortTable('community')">Community</th>
            <th style="min-width:110px" onclick="sortTable('parentIncome')">Parent Income</th>
            <th style="min-width:140px" onclick="sortTable('bankName')">Bank Name</th>
            <th style="min-width:140px">Account Number</th>
            <th style="min-width:100px">IFSC Code</th>
            <th style="min-width:250px">Scholarship Name(s)</th>
            <th style="min-width:120px">CWSN Disability</th>
            <th style="min-width:160px" onclick="sortTable('seedingStatus')">Bank Seeding Status</th>
            <th style="min-width:160px" onclick="sortTable('npciTimestamp')">NPCI Timestamp</th>
            <th style="min-width:140px" onclick="sortTable('paymentStatus')">Payment Status</th>
            <th style="min-width:180px">Failure Reason</th>
          </tr>
        </thead>
        <tbody id="table-body">
          <!-- Rendered by JS -->
        </tbody>
      </table>
      <div class="no-data" id="no-data" style="display:none">
        <div class="no-data-icon">🔍</div>
        <div class="no-data-title">No data available</div>
        <div class="no-data-sub">No scholarship records match your current filters. Try adjusting the class, section, or search query.</div>
      </div>
    </div>
    <div class="pagination-bar" id="pagination-bar">
      <div class="page-info" id="page-info">Page <strong>1</strong> of <strong>1</strong></div>
      <div class="page-btns" id="page-btns"></div>
    </div>
  </div>

</div>

<script>
// ── SAMPLE DATA ──
const SAMPLE_DATA = [
  {emisId:'33050101901001',name:'Abirami S.',class:'6',section:'A',gender:'Female',community:'SC',parentIncome:'72000',bankName:'State Bank of India',accountNo:'31204567890',ifsc:'SBIN0001234',scholarships:['SC/ST Post Matric','Chief Minister Scholarship'],cwsn:'Not Applicable',seedingStatus:'Seeded',npciTimestamp:'2024-03-15 10:22:34',paymentStatus:'Success',failureReason:''},
